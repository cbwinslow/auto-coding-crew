# Environment Configuration Template for Autonomous Coding Crew
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control - it contains secrets

# GitHub Token - used by various agents for repository operations, issue management, etc.
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN="your_github_token_here"

# Web Search API - used by researcher agent for fact-checking and information gathering
# Get from: https://brave.com/search/api/
BRAVE_API_KEY="your_brave_api_key_here"

# OpenRouter API - fallback or additional model access if needed
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Database Configuration (if needed for persistent agent memory)
# CBW_RAG_DATABASE="postgresql://user:password@localhost:5432/database"
# CBW_RAG_OLLAMA_URL="http://localhost:11434"
# CBW_RAG_EMBEDDING_MODEL="nomic-embed-text"

# Note: The primary LLM API key is handled by the OpenProse environment (Claude Code, OpenCode, or Amp)
# Individual agents do not get separate LLM API keys - they are subagent sessions within the same context